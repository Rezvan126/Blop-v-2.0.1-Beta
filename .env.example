# blop — Environment Variables
# Copy this file to .env.local and fill in your Firebase credentials.
# Never commit .env.local to version control.

# Firebase Project Configuration
# Find these values in the Firebase Console:
# Project Settings → Your apps → SDK setup and configuration

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=

# Development only — set to "true" to load demo seed data on first launch
# Leave unset or set to "false" in production
VITE_SEED_DATA=true
