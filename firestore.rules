rules_version = '2';

// ── blop Firestore Security Rules ─────────────────────────────────────────
//
// Deploy via Firebase Console → Firestore → Rules, or:
//   firebase deploy --only firestore:rules
//
// Identity model:
//   - Every client signs in anonymously; request.auth.uid is always set.
//   - Groups store ownerUid (creator) and memberUids (all authenticated members).
//   - Subcollection access is gated on the parent group's memberUids.

service cloud.firestore {
  match /databases/{database}/documents {

    // ── User profiles ──────────────────────────────────────────────────────
    // Only the owner can read or write their own profile.
    match /users/{userId} {
      allow read, write: if request.auth != null
                         && request.auth.uid == userId;
    }

    // ── Groups + subcollections ────────────────────────────────────────────
    match /groups/{groupId} {

      // Helper: is the caller an authenticated member of this group?
      function isMember() {
        return request.auth != null
               && request.auth.uid in resource.data.memberUids;
      }

      // Helper: is the caller still listed in the incoming write data?
      function isMemberIncoming() {
        return request.auth != null
               && request.auth.uid in request.resource.data.memberUids;
      }

      // Any authenticated user can create a group (they become ownerUid).
      allow create: if request.auth != null
                    && request.resource.data.ownerUid == request.auth.uid;

      // Only existing members can read.
      allow read: if isMember();

      // Existing members can update (must keep themselves in memberUids).
      // Non-members can join by ONLY appending themselves to memberUids.
      allow update: if (isMember() && isMemberIncoming())
                    || (!isMember() && isMemberIncoming() &&
                        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['memberUids']));

      // Hard-delete is disabled; use isArchived: true instead.
      allow delete: if false;

      // Helper to support batch writes (e.g. creating group + members at once)
      function isGroupMember(groupId) {
        let groupBefore = get(/databases/$(database)/documents/groups/$(groupId));
        let groupAfter = getAfter(/databases/$(database)/documents/groups/$(groupId));
        return request.auth != null && (
          (groupBefore != null && request.auth.uid in groupBefore.data.memberUids) ||
          (groupAfter != null && request.auth.uid in groupAfter.data.memberUids)
        );
      }

      // ── Members subcollection ──────────────────────────────────────────
      match /members/{memberId} {
        allow read, write: if isGroupMember(groupId);
      }

      // ── Expenses subcollection ─────────────────────────────────────────
      match /expenses/{expenseId} {
        allow read, write: if isGroupMember(groupId);
      }

      // ── Settlements subcollection ──────────────────────────────────────
      match /settlements/{settlementId} {
        allow read, write: if isGroupMember(groupId);
      }

      // ── Activity subcollection ─────────────────────────────────────────
      // Members can read and append; they cannot edit or delete past entries.
      match /activity/{activityId} {
        allow read: if isGroupMember(groupId);
        allow create: if isGroupMember(groupId);
        allow update: if isGroupMember(groupId);
        allow delete: if false;
      }
    }

    // ── Invite codes ───────────────────────────────────────────────────────
    // Any authenticated user can read an invite (needed to join).
    // Only the group owner (identified by ownerUid in the invite doc) can
    // create or update invite documents — prevents invite forgery.
    match /invites/{inviteCode} {
      allow read: if request.auth != null;

      // Create: caller must set themselves as ownerUid.
      allow create: if request.auth != null
                    && request.resource.data.ownerUid == request.auth.uid;

      // Update: caller must already be the ownerUid on the stored document.
      allow update: if request.auth != null
                    && resource.data.ownerUid == request.auth.uid;

      // Invite documents are never deleted (expiry handled in app logic).
      allow delete: if false;
    }

    // ── Legacy flat-snapshot documents (migration only) ───────────────────
    // Allow authenticated users to read/delete their own old document so
    // the migration helper can clean it up. No new writes allowed.
    match /blop/{syncKey} {
      allow read, delete: if request.auth != null;
      allow write:        if false;
    }

    // ── Deny everything else ───────────────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
