rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // User Profiles
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Splits (Groups)
    match /groups/{groupId} {
      // Users can only see/edit splits where they are a member
      allow read, update: if request.auth != null && (
        request.auth.uid in resource.data.memberUids
      );
      
      // Anyone authenticated can create a split
      allow create: if request.auth != null;
      
      // Subcollections
      match /members/{memberId} {
        allow read, write: if request.auth != null && (
          request.auth.uid in get(/databases/$(database)/documents/groups/$(groupId)).data.memberUids
        );
      }
      
      match /expenses/{expenseId} {
        allow read, write: if request.auth != null && (
          request.auth.uid in get(/databases/$(database)/documents/groups/$(groupId)).data.memberUids
        );
      }
      
      match /settlements/{settlementId} {
        allow read, write: if request.auth != null && (
          request.auth.uid in get(/databases/$(database)/documents/groups/$(groupId)).data.memberUids
        );
      }
      
      match /activity/{activityId} {
        allow read, write: if request.auth != null && (
          request.auth.uid in get(/databases/$(database)/documents/groups/$(groupId)).data.memberUids
        );
      }
    }

    // Invites
    match /invites/{inviteCode} {
      // Anyone can look up an invite by code
      allow read: if true;
      // Only the split owner can create/delete invites (handled via client logic + group rules)
      allow write: if request.auth != null;
    }
  }
}
